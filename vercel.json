{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,

  "installCommand": "npm install -g pnpm@9 && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/xiyora run build",
  "outputDirectory": "artifacts/xiyora/dist/public",

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
