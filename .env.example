# ── XIYORA Environment Variables ────────────────────────────────────────────
# Copy this file to .env for local development.
# In production (Vercel / Replit), set these as platform secrets/env vars.
# ⚠️  NEVER commit real values — this file is tracked by git.

# ── Database (required by API server + Drizzle ORM) ─────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Admin auth (required for admin panel and protected endpoints) ─────────────
# Generate a long random string. Admin endpoints return 403 if not set.
ADMIN_SECRET=
# Optional: legacy admin username/password for basic-auth flows
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── CORS (comma-separated list of allowed origins, merged with static list) ──
# Add your Vercel preview URL or custom domain here if needed.
ALLOWED_ORIGINS=https://xiyora.vercel.app,https://your-custom-domain.com

# ── Frontend API base (Vite build-time variable) ─────────────────────────────
# Set this in Vercel → Project Settings → Environment Variables.
# Must be the public URL of your deployed API server.
# Example: https://xiyora.vercel.app (if frontend + backend on same Vercel project)
# Example: https://xiyora--xiyora52.replit.app/api (if using Replit backend)
VITE_API_BASE=https://your-api-url.com/api

# ── WhatsApp Notifications (optional) ────────────────────────────────────────
# Meta Graph API v20.0. Required only if WhatsApp enquiry notifications are enabled.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_NOTIFY_TO=91XXXXXXXXXX

# ── Image Uploads — Cloudinary (recommended, works on Vercel + Replit) ────────
# Create a free account at https://cloudinary.com then copy these values from
# your Cloudinary dashboard. When set, Cloudinary is used automatically.
# Without these, uploads fall back to Replit Object Storage (Replit-only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Object Storage (Replit fallback, optional) ───────────────────────────────
# Only needed if you are running on Replit without Cloudinary configured.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development

# NOTE: PORT is injected automatically by Replit/Vercel runtime. Do not set manually.
