# ── XIYORA / API server environment ──────────────────────────
# Copy to your environment (Replit Secrets in dev/prod). Do NOT commit real values.

# PostgreSQL connection string (required by the API server + Drizzle)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Admin secret guarding admin GET endpoints (enquiries/subscriptions/checkout-intents lists).
# Requests must send header `x-admin-secret` matching this value, else 403.
# Generate a long random string. If unset, admin list endpoints stay locked.
ADMIN_SECRET=

# Session secret (reserved for session-based features).
SESSION_SECRET=

# Optional: log level for the API server (default: info). One of trace|debug|info|warn|error
LOG_LEVEL=info

# Optional: node environment (development|production)
NODE_ENV=development

# NOTE: PORT and BASE_PATH are injected automatically by the Replit workflow.
# Do not set them manually.
